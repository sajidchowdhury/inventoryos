# ── InventoryOS .gitignore ──

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (KEEP SECRETS OUT OF GIT)
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local

# BUT keep .env.example tracked (template without secrets)
!.env.example

# prisma
/prisma/migrations/dev.db

# local database
/db/
*.db
*.db-journal

# backup files (never commit backups)
/opt/backups/
*.sql

# logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db

# Upload directory (user-provided reference files)
/upload/

# Agent context (auto-generated)
/agent-ctx/
.z-ai-config
