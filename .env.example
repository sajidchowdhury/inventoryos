# ── InventoryOS environment template ──
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`
# (it is git-ignored). Only this `.env.example` template belongs in the repo.

# ── Database (PostgreSQL) ──
# Pooled/runtime connection (through PgBouncer in production).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# Direct connection (bypasses the pooler) — used by prisma migrate/db push.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ── Runtime ──
NODE_ENV="development"
PORT="3000"
HOSTNAME="0.0.0.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="InventoryOS"

# ── Security / secrets (generate strong random values; do NOT reuse examples) ──
JWT_SECRET="change-me-to-a-long-random-string"
SUPER_ADMIN_DEFAULT_PASSWORD="change-me"
CRON_SECRET="change-me-to-a-long-random-string"

# ── Redis (optional) ──
# If unset, the cache falls back to an in-memory store (single-instance only).
# REDIS_URL="redis://127.0.0.1:6379"

# ── AI provider (z-ai-web-dev-sdk) — optional ──
ZAI_API_KEY=""
ZAI_API_BASE=""

# ── Email / SMTP (optional; can also be configured from the super-admin panel) ──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ── Sentry (optional) ──
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
