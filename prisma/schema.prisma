// ── InventoryOS Database Schema ──
// Multi-tenant inventory management platform
// Phase 1a: Pharmacy product master with batch tracking

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Business Types ──
model BusinessType {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String
  color     String
  isActive  Boolean  @default(false)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses Business[]
}

// ── Users ──
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses Business[]
}

// ── Businesses ──
model Business {
  id             String   @id @default(cuid())
  userId         String
  businessTypeId String
  name           String
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessType BusinessType @relation(fields: [businessTypeId], references: [id])
  businessUsers BusinessUser[]
  categories    Category[]
  products      Product[]
  transactions  Transaction[]
  inventories   Inventory[]
  batches       Batch[]
  alertPreference AlertPreference?
  notificationLogs NotificationLog[]
  customers     Customer[]
  sales         Sale[]
  saleItems     SaleItem[]

  @@index([userId])
  @@index([businessTypeId])
}

// ── Business Users ──
model BusinessUser {
  id           String   @id @default(cuid())
  businessId   String
  username     String
  passwordHash String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([businessId, username])
  @@index([businessId])
}

// ── Categories ──
// Product categories with color, icon, and hierarchy support
model Category {
  id         String   @id @default(cuid())
  businessId String
  parentId   String?
  name       String
  slug       String              // URL-friendly: "antibiotics", "pain-relief"
  icon       String   @default("Tag")   // Lucide icon name
  color      String   @default("#6B7280") // Category brand color
  type       String   @default("medicine") // "medicine", "surgical", "cosmetic", "supplement", "baby-care", "other"
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([parentId])
}

// ── Products (Base + Pharmacy Extension) ──
// Unified product model with pharmacy-specific optional fields
model Product {
  id           String   @id @default(cuid())
  businessId   String
  categoryId   String?
  name         String              // Brand name (e.g., "Napa Extra")
  genericName  String?             // Generic name (e.g., "Paracetamol + Caffeine")
  sku          String?             // Internal SKU code
  barcode      String?             // Barcode / QR code
  productType  String   @default("medicine") // "medicine", "surgical", "cosmetic", "supplement", "baby-care", "other"

  // Unit & Conversion
  unit         String   @default("piece")  // Base unit: "piece", "tablet", "ml", "g"
  stripSize    Int?              // e.g., 10 tablets per strip
  boxSize      Int?              // e.g., 10 strips per box

  // Pharmacy-specific
  strength     String?            // "500mg", "250mg/5ml"
  dosageForm   String?            // "Tablet", "Capsule", "Syrup", "Injection", "Cream"
  manufacturer String?            // "Square", "Beximco", "Renata"
  scheduleType String?            // "OTC", "Schedule_H", "Schedule_H1", "Schedule_X", "Narcotic"
  hsnCode      String?            // For VAT: "30049099"
  vatRate      Float   @default(0)    // VAT percentage (medicines have reduced rate)
  mrp          Float?             // Maximum Retail Price
  isPrescription Boolean @default(false) // Prescription required?
  storageCondition String?        // "Room Temp", "Fridge (2-8C)", "Cool & Dry"
  rackNo       String?            // Shelf location: "A3", "Rack-5"

  // Stock thresholds
  minStock     Float   @default(0)     // Low stock alert threshold
  maxStock     Float   @default(0)     // Overstock warning threshold
  reorderLevel Float   @default(0)     // When to reorder

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])
  inventory    Inventory?
  transactions Transaction[]
  batches      Batch[]
  saleItems    SaleItem[]

  @@index([businessId])
  @@index([categoryId])
  @@index([genericName])
  @@index([manufacturer])
}

// ── Batch ──
// Multi-batch tracking per product with expiry management
model Batch {
  id            String   @id @default(cuid())
  businessId    String
  productId     String
  batchNo       String              // Batch number from manufacturer
  mfgDate       DateTime?           // Manufacturing date
  expiryDate    DateTime            // Expiry date (CRITICAL)
  quantity      Float    @default(0)  // Current quantity in this batch
  purchasePrice Float?              // Cost price per unit for this batch
  mrp           Float?              // Selling price per unit
  supplierId    String?             // Supplier reference (Phase 5)
  status        String   @default("active") // "active", "near_expiry", "expired", "quarantined", "returned", "destroyed"
  notes         String?             // Optional notes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([productId])
  @@index([expiryDate])
  @@index([status])
}

// ── Inventory ──
// Aggregated stock levels per product (sum of all batches)
model Inventory {
  id         String   @id @default(cuid())
  businessId String
  productId  String   @unique
  quantity   Float    @default(0)
  minStock   Float    @default(0)
  unitCost   Float?
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ── Transactions ──
model Transaction {
  id         String   @id @default(cuid())
  businessId String
  productId  String
  batchId    String?             // Link to specific batch
  type       String              // "PURCHASE", "SALE", "ADJUSTMENT", "WASTE", "RETURN"
  quantity   Float
  unitPrice  Float?              // Price per unit at transaction time
  note       String?
  createdBy  String?             // BusinessUser ID who performed the action
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([productId])
  @@index([createdAt])
}

// ── OTP Verification ──
model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

// ── Sessions ──
model Session {
  id           String   @id @default(cuid())
  businessUserId String
  token        String   @unique
  deviceInfo   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  businessUser BusinessUser @relation(fields: [businessUserId], references: [id], onDelete: Cascade)

  @@index([businessUserId])
  @@index([token])
  @@index([expiresAt])
}

// ── Alert Preferences ──
// Per-business notification settings (one record per business)
model AlertPreference {
  id              String   @id @default(cuid())
  businessId      String   @unique

  // Expiry alert thresholds (in days before expiry)
  expiryCriticalDays  Int @default(7)    // Red alert threshold
  expiryWarningDays   Int @default(30)   // Orange alert threshold
  expiryNoticeDays    Int @default(90)   // Yellow alert threshold

  // Low stock alert
  lowStockEnabled   Boolean @default(true)
  lowStockThreshold Int     @default(10) // Absolute quantity threshold

  // Quarantine alerts
  quarantineAlerts  Boolean @default(true)

  // Notification channels (for future email/SMS integration)
  emailEnabled      Boolean @default(false)
  email             String?
  smsEnabled        Boolean @default(false)
  phone             String?

  // Digest frequency
  digestFrequency   String  @default("daily") // "daily", "weekly", "monthly", "none"

  // Quiet hours (alerts still recorded, just not pushed)
  quietHoursStart   Int?    // Hour 0-23
  quietHoursEnd     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ── Notification Log ──
// Records each alert generated (for audit + dedup)
model NotificationLog {
  id          String   @id @default(cuid())
  businessId  String
  type        String   // "expiry_critical", "expiry_warning", "low_stock", "quarantine", "disposed"
  severity    String   // "critical", "warning", "info"
  title       String
  message     String
  entityType  String   // "batch", "product", "category"
  entityId    String?  // ID of related batch/product
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ── Customers ──
// Pharmacy customers (optional — walk-in sales use null customerId)
model Customer {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  phone       String?
  email       String?
  address     String?
  dateOfBirth DateTime?
  gender      String?  // "male", "female", "other"
  // Chronic condition flags (for pharmacy context)
  chronicConditions String? // comma-separated: "diabetes,hypertension"
  allergies         String? // comma-separated: "penicillin,sulfa"
  notes             String?
  // Loyalty / credit
  totalSpent  Float    @default(0)
  visitCount  Int      @default(0)
  lastVisitAt DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([businessId])
  @@index([phone])
  @@index([name])
}

// ── Sales (Invoices) ──
// Each sale is an invoice with multiple line items
model Sale {
  id              String   @id @default(cuid())
  businessId      String
  customerId      String?  // null for walk-in customers
  invoiceNo       String   // human-readable: INV-2026-0001
  status          String   @default("completed") // "completed", "cancelled", "refunded", "pending"
  paymentMethod   String   @default("cash") // "cash", "card", "mobile_banking", "credit", "mixed"
  paymentStatus   String   @default("paid") // "paid", "partial", "unpaid", "refunded"

  // Pricing breakdown
  subtotal        Float    @default(0)  // sum of (item.price * item.quantity)
  discountAmount  Float    @default(0)  // flat discount
  discountPercent Float    @default(0)  // percentage discount (0-100)
  taxAmount       Float    @default(0)  // VAT/tax
  totalAmount     Float    @default(0)  // final amount customer pays
  paidAmount      Float    @default(0)  // amount actually paid (for partial payments)

  // Metadata
  itemCount       Int      @default(0)
  totalQuantity   Float    @default(0)
  notes           String?

  // Audit
  createdBy       String?  // BusinessUser ID
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    SaleItem[]

  @@unique([businessId, invoiceNo])
  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ── Sale Items (Invoice Line Items) ──
model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  businessId  String
  productId   String
  batchId     String?  // specific batch that fulfilled this item (FEFO)
  productName String   // snapshot at time of sale
  genericName String?  // snapshot
  batchNo     String?  // snapshot
  quantity    Float
  unit        String   // snapshot
  unitPrice   Float    // price per unit (MRP at time of sale)
  discountPercent Float @default(0)  // per-line discount
  totalPrice  Float    // quantity * unitPrice * (1 - discountPercent/100)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([batchId])
}
